{
  "AllowedHosts": "*",
  "Api": {
    "Title": "PokéCraft API",
    "Version": "0.1.0",
    "Build": null
  },
  "Caching": {
    "ActorLifetime": "01:00:00"
  },
  "Cookies": {
    "RefreshToken": {
      "HttpOnly": true,
      "MaxAge": "7.00:00:00",
      "SameSite": "Strict",
      "Secure": true
    },
    "Session": {
      "SameSite": "Strict"
    }
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [],
    "AllowAnyMethod": false,
    "AllowedMethods": [],
    "AllowAnyHeader": false,
    "AllowedHeaders": [],
    "AllowCredentials": false
  },
  "Krakenar": {
    "Realm": "pokegame"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Permissions": {
    "WorldLimit": 3
  },
  "Retry": {
    "Algorithm": "Exponential",
    "Delay": 100,
    "ExponentialBase": 2,
    "RandomVariation": 0,
    "MaximumRetries": 5,
    "MaximumDelay": 0
  }
}
