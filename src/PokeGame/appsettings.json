{
  "AllowedHosts": "*",
  "Api": {
    "Title": "PokéCraft API",
    "Version": "0.1.0"
  },
  "Authentication": {
    "AccessToken": {
      "Type": "at+jwt",
      "LifetimeSeconds": 300
    }
  },
  "Caching": {
    "ActorLifetime": "01:00:00"
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [],
    "AllowAnyMethod": false,
    "AllowedMethods": [],
    "AllowAnyHeader": false,
    "AllowedHeaders": [],
    "AllowCredentials": false
  },
  "Krakenar": {
    "Realm": "pokecraft"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Membership": {
    "InvitationLifetimeDays": 7
  },
  "Permissions": {
    "WorldLimit": 3
  },
  "Retry": {
    "Algorithm": "None",
    "Delay": 0,
    "ExponentialBase": 0,
    "RandomVariation": 0,
    "MaximumRetries": 0,
    "MaximumDelay": 0
  },
  "Storage": {
    "AllocatedBytes": 1073741824
  }
}
